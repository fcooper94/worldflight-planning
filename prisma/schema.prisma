generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model OfficialTeam {
  id                Int      @id @default(autoincrement())
  teamName          String
  callsign          String
  mainCid           Int
  aircraftType      String
  country           String
  participatingWf26 Boolean  @default(false)
  createdAt         DateTime @default(now())
}

model Affiliate {
  id                Int      @id @default(autoincrement())
  callsign          String
  simType           String
  cid               Int
  participatingWf26 Boolean  @default(false)
  createdAt         DateTime @default(now())
}

model DepFlow {
  id        Int      @id @default(autoincrement())
  sector    String   @unique
  rate      Int
  flowtype  String   @default("NONE")
  updatedAt DateTime @updatedAt
}

model TobtBooking {
  id           Int      @id @default(autoincrement())
  slotKey      String
  cid          Int
  callsign     String
  from         String
  to           String
  dateUtc      String
  depTimeUtc   String
  tobtTimeUtc  String?
  createdAt    DateTime @default(now())

  @@unique([cid, slotKey])   // ✅ THIS
}


model User {
  cid  Int    @id
  name String
}

model Airport {
  icao    String   @id
  name    String?
  lat     Float
  lon     Float
  elev    Int?
  runways Runway[]
}

model Runway {
  id          Int     @id @default(autoincrement())
  airportIcao String
  ident1      String?
  ident2      String?
  lat1        Float
  lon1        Float
  lat2        Float
  lon2        Float
  airport     Airport @relation(fields: [airportIcao], references: [icao], onDelete: Cascade, onUpdate: NoAction, map: "runway_airport_fk")
}

model AirportScenery {
  id          Int         @id @default(autoincrement())
  icao        String
  sim         Simulator
  name        String
  developer   String?
  store       String?
  url         String
  type        SceneryType
  submittedBy String
  submittedAt DateTime    @default(now())
  approved    Boolean     @default(false)
  approvedBy  String?
  approvedAt  DateTime?

  @@index([icao])
  @@index([approved])
}

model DocumentationPermission {
  id        Int      @id @default(autoincrement())
  cid       Int
  pattern   String
  createdAt DateTime @default(now())

  @@index([cid])
}

model AirportDocument {
  id         Int      @id @default(autoincrement())
  icao       String   @db.VarChar(4)
  filename   String
  uploadedBy Int
  uploadedAt DateTime @default(now()) @db.Timestamp(6)

  @@unique([icao, filename])
  @@index([icao])
}

model DocumentationAccessRequest {
  id          Int       @id @default(autoincrement())
  cid         Int
  pattern     String    @db.VarChar(4)
  name        String?
  email       String?
  role        String?   @db.VarChar(20)
  requestedAt DateTime  @default(now()) @db.Timestamp(6)
  status      String    @default("PENDING") @db.VarChar(20)
  reviewedBy  Int?
  reviewedAt  DateTime? @db.Timestamp(6)
  createdAt   DateTime  @default(now()) @db.Timestamp(6)

  @@index([cid])
  @@index([status])
}

model WfVisitedAirport {
  id        Int      @id @default(autoincrement())
  icao      String   @db.VarChar(4)
  year      Int
  eventName String?

  @@unique([icao, year])
  @@index([icao])
}

model AirportSuggestion {
  id          Int      @id @default(autoincrement())
  firstName   String
  lastName    String
  icao        String   @db.VarChar(4)
  type        String   @default("visit") @db.VarChar(10)
  association String
  reason      String
  contact     String
  cid         Int?
  createdAt   DateTime @default(now())

  @@index([icao])
  @@index([type])
}

model MailingListSubscriber {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  firstName String?
  lastName  String?
  cid       Int?
  createdAt DateTime @default(now())

  @@index([email])
}

model PageVisibility {
  key     String  @id
  enabled Boolean @default(true)
}

model SiteSetting {
  key   String @id
  value String
}

enum Simulator {
  MSFS
  XPLANE
  P3D
}

enum SceneryType {
  Freeware
  Payware
}