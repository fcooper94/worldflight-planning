generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model OfficialTeam {
  id                Int      @id @default(autoincrement())
  teamName          String
  callsign          String
  mainCid           Int
  aircraftType      String
  country           String
  participatingWf26 Boolean  @default(false)
  createdAt         DateTime @default(now())
}

model Affiliate {
  id                Int      @id @default(autoincrement())
  callsign          String
  simType           String
  cid               Int
  participatingWf26 Boolean  @default(false)
  createdAt         DateTime @default(now())
}

model DepFlow {
  id        Int      @id @default(autoincrement())
  eventId   Int
  sector    String
  rate      Int
  flowtype  String   @default("NONE")
  updatedAt DateTime @updatedAt

  @@unique([eventId, sector])
  @@index([eventId])
}

model TobtBooking {
  id           Int      @id @default(autoincrement())
  slotKey      String
  cid          Int
  callsign     String
  from         String
  to           String
  dateUtc      String
  depTimeUtc   String
  tobtTimeUtc  String?
  manual       Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@unique([cid, slotKey])
}

model User {
  cid  Int    @id
  name String
}

model Airport {
  icao    String   @id
  name    String?
  lat     Float
  lon     Float
  elev    Int?
  runways Runway[]
}

model Runway {
  id          Int     @id @default(autoincrement())
  airportIcao String
  ident1      String?
  ident2      String?
  lat1        Float
  lon1        Float
  lat2        Float
  lon2        Float
  airport     Airport @relation(fields: [airportIcao], references: [icao], onDelete: Cascade)
}

model AirportScenery {
  id          Int      @id @default(autoincrement())
  icao        String
  sim         String
  name        String
  developer   String?
  store       String?
  url         String
  type        String
  submittedBy String
  submittedAt DateTime @default(now())
  approved    Boolean  @default(false)
  approvedBy  String?
  approvedAt  DateTime?

  @@index([icao])
  @@index([approved])
}

model DocumentationPermission {
  id        Int      @id @default(autoincrement())
  cid       Int
  pattern   String
  createdAt DateTime @default(now())

  @@index([cid])
}

model AirportDocument {
  id         Int      @id @default(autoincrement())
  icao       String
  filename   String
  uploadedBy Int
  uploadedAt DateTime @default(now())

  @@unique([icao, filename])
  @@index([icao])
}

model DocumentationAccessRequest {
  id          Int       @id @default(autoincrement())
  cid         Int
  pattern     String
  name        String?
  email       String?
  role        String?
  requestedAt DateTime  @default(now())
  status      String    @default("PENDING")
  reviewedBy  Int?
  reviewedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([cid])
  @@index([status])
}

model StaffAccessRequest {
  id          Int       @id @default(autoincrement())
  cid         Int
  division    String
  name        String?
  email       String?
  role        String?
  rating      String?
  status      String    @default("PENDING")
  reviewedBy  Int?
  reviewedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([cid])
  @@index([status])
}

model MasterToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  cid       Int?
  label     String?
  createdAt DateTime @default(now())
  usedAt    DateTime?

  @@index([token])
  @@index([cid])
}

model UserAdditionalRole {
  id               Int      @id @default(autoincrement())
  cid              Int
  role             String
  teamName         String?
  canEditBookings  Boolean  @default(true)
  canManageMembers Boolean  @default(false)
  participating    Boolean  @default(true)
  createdAt        DateTime @default(now())

  @@unique([cid, role])
  @@index([cid])
}

model WfVisitedAirport {
  id        Int      @id @default(autoincrement())
  icao      String
  year      Int
  eventName String?

  @@unique([icao, year])
  @@index([icao])
}

model AirportSuggestion {
  id          Int      @id @default(autoincrement())
  firstName   String
  lastName    String
  icao        String
  type        String   @default("visit")
  association String
  reason      String
  contact     String
  notify      Boolean  @default(false)
  cid         Int?
  createdAt   DateTime @default(now())

  @@index([icao])
  @@index([type])
}

model TobtBookingBackup {
  id           Int      @id @default(autoincrement())
  eventId      Int
  slotKey      String
  cid          Int
  callsign     String
  from         String
  to           String
  dateUtc      String
  depTimeUtc   String
  tobtTimeUtc  String?
  originalId   Int
  backedUpAt   DateTime @default(now())

  @@index([eventId])
}

model WfScheduleRow {
  id          Int    @id @default(autoincrement())
  eventId     Int
  sortOrder   Int    @default(0)
  number      String
  from        String
  to          String
  dateUtc     String @default("")
  depTimeUtc  String @default("")
  arrTimeUtc  String @default("")
  blockTime   String @default("")
  flightTime  String @default("")
  atcRoute    String @default("")

  @@unique([eventId, number])
  @@index([eventId])
}

model WfEvent {
  id             Int      @id @default(autoincrement())
  name           String
  year           Int
  sheetUrl       String   @default("")
  mode           String   @default("csv")
  isActive       Boolean  @default(false)
  turnaroundMins Int      @default(45)
  isWorldFlight  Boolean  @default(true)
  flightSuffix   String   @default("")
  flightStartNumber Int   @default(1)
  aircraftType   String   @default("B738")
  costIndex      Int      @default(30)
  startDateUtc   String   @default("")
  startTimeUtc   String   @default("")
  nextSectorAfter String  @default("BLOCK")
  cruiseAltitude Int      @default(0)
  cruiseMode     String   @default("CI")
  createdAt      DateTime @default(now())

  @@unique([year])
}

model PageVisibility {
  key     String  @id
  enabled Boolean @default(true)
}

model MailingListSubscriber {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  firstName String?
  lastName  String?
  cid       Int?
  createdAt DateTime @default(now())

  @@index([email])
}

model SiteSetting {
  key   String @id
  value String
}
