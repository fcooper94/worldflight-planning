{
  "name": "worldflight-cdm",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "prisma:generate": "npx prisma generate --schema=prisma/schema.$DB_ENGINE.prisma",
    "prisma:migrate": "npx prisma migrate deploy --schema=prisma/schema.$DB_ENGINE.prisma",

    "postinstall": "npm run prisma:generate",
    "start": "npm run prisma:migrate && node index.js"
  },
  "dependencies": {
    "@libsql/client": "^0.15.15",
    "@prisma/adapter-libsql": "^7.1.0",
    "@prisma/client": "6.12.0",
    "axios": "^1.13.2",
    "csv-parser": "^3.2.0",
    "dotenv": "^16.6.1",
    "express": "^4.19.2",
    "express-session": "^1.17.3",
    "node-cron": "^4.2.1",
    "prisma": "6.12.0",
    "socket.io": "^4.8.1"
  }
}
